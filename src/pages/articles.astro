---
import Layout from '../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

type Article = CollectionEntry<'articles'>;

const articles = (await getCollection('articles', ({ data }: Article) => !data.draft))
  .sort((a: Article, b: Article) => b.data.date.getTime() - a.data.date.getTime());

const slug = (article: Article) => article.id.replace(/\.(md|mdx)$/, '');
---

<Layout title="Articles · Adam Cordeiro" description="Writing on statistics, math, and machine learning.">
  <main>
    <header>
      <a href="/" class="back">← Home</a>
      <button id="theme-toggle" aria-label="Toggle light/dark mode">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </header>

    <section class="content">
      <span class="page-icon">📝</span>
      <h1>Articles</h1>
      <p class="subtitle">Writing on statistics, math, and machine learning.</p>

      {articles.length === 0 ? (
        <p class="empty">No articles yet — check back soon.</p>
      ) : (
        <ul class="article-list">
          {articles.map((article: CollectionEntry<'articles'>) => (
            <li>
              <a href={`/articles/${slug(article)}`} class="article-link">
                <span class="article-title">{article.data.title}</span>
                <span class="article-date">
                  {article.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </span>
                <span class="article-desc">{article.data.description}</span>
              </a>
            </li>
          ))}
        </ul>
      )}
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
  }

  .back {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s;
  }

  .back:hover {
    color: var(--accent);
    text-decoration: none;
  }

  #theme-toggle {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 1rem;
    box-shadow: var(--shadow);
    transition: background 0.2s, border-color 0.2s;
  }

  #theme-toggle:hover { border-color: var(--accent); }

  .icon-sun { display: none; }
  .icon-moon { display: inline; }
  :global(html.dark) .icon-sun { display: inline; }
  :global(html.dark) .icon-moon { display: none; }

  .content { display: flex; flex-direction: column; gap: 0.5rem; }

  .page-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 1.5rem;
  }

  .empty {
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 500;
  }

  .article-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .article-link {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 0.2rem 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    box-shadow: var(--shadow);
    transition: border-color 0.2s, transform 0.15s;
  }

  .article-link:hover {
    border-color: var(--accent);
    transform: translateX(3px);
    text-decoration: none;
    color: var(--text);
  }

  .article-title {
    font-weight: 600;
    font-size: 1rem;
  }

  .article-date {
    color: var(--text-muted);
    font-size: 0.8rem;
    white-space: nowrap;
    align-self: center;
  }

  .article-desc {
    color: var(--text-muted);
    font-size: 0.875rem;
    grid-column: 1 / -1;
  }
</style>
