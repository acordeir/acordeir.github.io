---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Projects · Adam Cordeiro" description="Open source work and things I've built.">
  <main>
    <header>
      <a href="/" class="back">← Home</a>
      <button id="theme-toggle" aria-label="Toggle light/dark mode">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </header>

    <section class="content">
      <span class="page-icon">🔧</span>
      <h1>Projects</h1>
      <p class="subtitle">Open source work and things I've built.</p>
      <p class="coming-soon">Coming soon — check back later.</p>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
  }

  .back {
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
    text-decoration: none;
  }

  .back:hover {
    color: var(--accent);
    text-decoration: none;
  }

  #theme-toggle {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 1rem;
    box-shadow: var(--shadow);
    transition: background 0.2s, border-color 0.2s;
  }

  #theme-toggle:hover { border-color: var(--accent); }

  .icon-sun { display: none; }
  .icon-moon { display: inline; }
  :global(html.dark) .icon-sun { display: inline; }
  :global(html.dark) .icon-moon { display: none; }

  .content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .page-icon {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  h1 {
    font-size: 2.25rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin-bottom: 1rem;
  }

  .coming-soon {
    color: var(--accent);
    font-size: 0.95rem;
    font-weight: 500;
  }
</style>
