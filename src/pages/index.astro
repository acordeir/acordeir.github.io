---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adam Cordeiro">
  <main>
    <header>
      <button id="theme-toggle" aria-label="Toggle light/dark mode">
        <span class="icon-sun">☀️</span>
        <span class="icon-moon">🌙</span>
      </button>
    </header>

    <section class="hero">
      <h1>Adam Cordeiro</h1>
      <p class="tagline">Data Scientist · Statistician · Builder</p>
      <p class="bio">
        I work at the intersection of statistics and machine learning — building models,
        writing about mathematical ideas, and making interactive tools that make hard
        concepts a little more intuitive.
      </p>

      <div class="contact">
        <a href="mailto:adam.h.cordeiro@gmail.com" class="contact-link">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
          adam.h.cordeiro@gmail.com
        </a>
        <a href="https://github.com/acordeir" class="contact-link" target="_blank" rel="noopener">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2z"/></svg>
          github.com/acordeir
        </a>
      </div>
    </section>

    <nav class="nav-grid">
      <a href="/articles" class="nav-card">
        <span class="nav-icon">📝</span>
        <h2>Articles</h2>
        <p>Writing on statistics, math, and machine learning.</p>
        <span class="nav-arrow">→</span>
      </a>
      <a href="/apps" class="nav-card">
        <span class="nav-icon">🧪</span>
        <h2>Apps</h2>
        <p>Interactive simulations and data science tools.</p>
        <span class="nav-arrow">→</span>
      </a>
      <a href="/projects" class="nav-card">
        <span class="nav-icon">🔧</span>
        <h2>Projects</h2>
        <p>Open source work and things I've built.</p>
        <span class="nav-arrow">→</span>
      </a>
    </nav>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 3rem;
  }

  #theme-toggle {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.4rem 0.75rem;
    cursor: pointer;
    font-size: 1rem;
    box-shadow: var(--shadow);
    transition: background 0.2s, border-color 0.2s;
  }

  #theme-toggle:hover {
    border-color: var(--accent);
  }

  .icon-sun { display: none; }
  .icon-moon { display: inline; }
  :global(html.dark) .icon-sun { display: inline; }
  :global(html.dark) .icon-moon { display: none; }

  .hero {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: 0.25rem;
  }

  .tagline {
    color: var(--accent);
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 1.25rem;
  }

  .bio {
    color: var(--text-muted);
    font-size: 1.05rem;
    max-width: 580px;
    margin-bottom: 1.75rem;
  }

  .contact {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-muted);
    font-size: 0.9rem;
    transition: color 0.15s;
  }

  .contact-link:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .nav-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1rem;
  }

  .nav-card {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    color: var(--text);
    text-decoration: none;
    box-shadow: var(--shadow);
    transition: border-color 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .nav-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
    text-decoration: none;
    color: var(--text);
  }

  .nav-icon {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
  }

  .nav-card h2 {
    font-size: 1.1rem;
    font-weight: 600;
  }

  .nav-card p {
    font-size: 0.875rem;
    color: var(--text-muted);
    flex: 1;
  }

  .nav-arrow {
    font-size: 1rem;
    color: var(--accent);
    margin-top: 0.5rem;
  }
</style>
